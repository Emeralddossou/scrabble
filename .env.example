# ================================
# SCRABBLE GAME - ENVIRONMENT CONFIG
# ================================
# Copy this file to .env and fill in your values
# DO NOT COMMIT .env to version control!

# ================================
# DATABASE CONFIGURATION
# ================================

# Type of database: 'sqlite' or 'mysql'
DB_TYPE=mysql

# For MySQL (default):
DB_HOST=localhost
DB_PORT=3306
DB_USER=scrabble_user
DB_PASS=your_secure_password
DB_NAME=scrabble

# For SQLite (legacy, not recommended):
# DB_TYPE=sqlite
# DB_FILE=data/scrabble.db

# ================================
# FTP DEPLOYMENT CONFIGURATION
# ================================
# Used for GitHub Actions auto-deployment
FTP_HOST=ftpupload.net
FTP_USER=your_ftp_username
FTP_PASS=your_ftp_password
FTP_PATH=/htdocs

# ================================
# APPLICATION SETTINGS
# ================================
APP_ENV=development
APP_DEBUG=false

# For production, set:
# APP_ENV=production
# APP_DEBUG=false

